<div class="tab-pane fade show active" id="tasksPane">
  <div class="toolbar">
    <h2>Tasklar</h2>
    <span class="live-indicator" id="taskLiveState">live</span>
  </div>
  <div id="tasks" class="tasks"></div>
  <div id="taskPager" class="mt-3"></div>
</div>

<div class="modal fade" id="candidateModal" tabindex="-1" aria-labelledby="candidateModalTitle" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="candidateModalTitle">Bulunan adresler</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <div class="modal-body" id="candidateModalBody"></div>
    </div>
  </div>
</div>

<div class="modal fade" id="taskEditModal" tabindex="-1" aria-labelledby="taskEditModalTitle" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <form id="taskEditForm">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="taskEditModalTitle">Task düzenle</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="editTaskId">
          <div class="vstack gap-3">
            <div>
              <label for="editKeywords" class="form-label">Keywordler</label>
              <textarea class="form-control" id="editKeywords" rows="4"></textarea>
            </div>
            <div>
              <label for="editTargetAddress" class="form-label">Targeted site</label>
              <input class="form-control" id="editTargetAddress">
            </div>
            <div class="row g-3">
              <div class="col-md-4">
                <label for="editCount" class="form-label">Click sayısı</label>
                <input class="form-control" id="editCount" type="number" min="1" max="50">
              </div>
              <div class="col-md-4">
                <label for="editDurationHours" class="form-label">Süre (saat)</label>
                <input class="form-control" id="editDurationHours" type="number" min="0" max="720" step="0.01">
              </div>
              <div class="col-md-4">
                <label for="editMaxAttempts" class="form-label">Retry</label>
                <input class="form-control" id="editMaxAttempts" type="number" min="1" max="10">
              </div>
            </div>
            <div>
              <label for="editMaxConcurrentBrowsers" class="form-label">Aynı anda tarayıcı</label>
              <div class="input-group">
                <input class="form-control" id="editMaxConcurrentBrowsers" type="number" min="1">
                <button class="btn btn-outline-secondary" type="button" data-apply-browser-capacity="edit">Önerilen</button>
              </div>
              <div class="capacity-hint" data-browser-capacity-hint="edit">Tarayıcı kapasitesi hesaplanıyor...</div>
            </div>
            <div class="row g-3 align-items-end">
              <div class="col-md-6">
                <label for="editDeviceMode" class="form-label">Ekran</label>
                <select class="form-select" id="editDeviceMode">
                  <option value="desktop">Desktop</option>
                  <option value="mobile">Mobil</option>
                </select>
              </div>
              <div class="col-md-6">
                <div class="form-check form-switch mb-2">
                  <input class="form-check-input" type="checkbox" role="switch" id="editHeadless">
                  <label class="form-check-label" for="editHeadless">Headless</label>
                </div>
              </div>
            </div>
            <div>
              <label for="editProxyUrl" class="form-label">Proxy</label>
              <input class="form-control" id="editProxyUrl" placeholder="http://user:pass@host:port veya socks5://user:pass@host:port" data-proxy-url="edit">
              <div class="proxy-builder mt-2" data-proxy-builder="edit">
                <div class="row g-2">
                  <div class="col-5">
                    <label class="form-label small" for="editProxyProtocol">Tip</label>
                    <select class="form-select" id="editProxyProtocol" data-proxy-field="protocol">
                      <option value="http">HTTP</option>
                      <option value="https">HTTPS</option>
                      <option value="socks5" selected>SOCKS5</option>
                      <option value="socks5h">SOCKS5H</option>
                      <option value="socks4">SOCKS4</option>
                      <option value="socks4a">SOCKS4A</option>
                    </select>
                  </div>
                  <div class="col-7">
                    <label class="form-label small" for="editProxyPort">Port</label>
                    <input class="form-control" id="editProxyPort" data-proxy-field="port" placeholder="8180">
                  </div>
                  <div class="col-12">
                    <label class="form-label small" for="editProxyHost">Host</label>
                    <input class="form-control" id="editProxyHost" data-proxy-field="host" placeholder="ankara8.buymobileproxy.com">
                  </div>
                  <div class="col-6">
                    <label class="form-label small" for="editProxyUsername">Kullanıcı</label>
                    <input class="form-control" id="editProxyUsername" data-proxy-field="username" placeholder="opsiyonel">
                  </div>
                  <div class="col-6">
                    <label class="form-label small" for="editProxyPassword">Şifre</label>
                    <input class="form-control" id="editProxyPassword" data-proxy-field="password" placeholder="opsiyonel">
                  </div>
                </div>
                <div class="proxy-preview mt-2" data-proxy-preview="edit">Proxy boş.</div>
              </div>
            </div>
            <div class="cookie-input-group" data-cookie-input-group="edit">
              <label class="form-label">Cookie</label>
              <div class="btn-group w-100 cookie-source-toggle" role="group" aria-label="Cookie kaynağı">
                <input type="radio" class="btn-check" name="editCookieSource" id="editCookieSourceText" value="text" autocomplete="off" checked>
                <label class="btn btn-outline-secondary" for="editCookieSourceText">Metin gir</label>
                <input type="radio" class="btn-check" name="editCookieSource" id="editCookieSourceFile" value="file" autocomplete="off">
                <label class="btn btn-outline-secondary" for="editCookieSourceFile">Dosya yükle</label>
                <input type="radio" class="btn-check" name="editCookieSource" id="editCookieSourcePool" value="pool" autocomplete="off">
                <label class="btn btn-outline-secondary" for="editCookieSourcePool">Havuzdan kullan</label>
              </div>
              <textarea class="form-control mt-2" id="editCookies" rows="4" data-cookie-text></textarea>
              <input class="form-control mt-2 d-none" id="editCookieFile" type="file" data-cookie-file accept=".txt,.json,.cookies,text/plain,application/json" multiple>
              <div class="form-text" data-cookie-file-name></div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
          <button type="submit" class="btn btn-primary" id="taskEditSaveBtn">Kaydet ve yeniden başlat</button>
        </div>
      </form>
    </div>
  </div>
</div>
