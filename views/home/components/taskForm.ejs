<div class="panel">
  <div class="panel-header">
    <h1>Yeni task</h1>
  </div>
  <form id="taskForm" class="vstack gap-3" autocomplete="off">
    <div>
      <label for="keywords" class="form-label">Keywordler</label>
      <textarea class="form-control" id="keywords" rows="6" placeholder="facebook&#10;instagram login"></textarea>
    </div>

    <div>
      <label for="targetAddress" class="form-label">Targeted site</label>
      <input class="form-control" id="targetAddress" placeholder="facebook.com">
    </div>

    <div class="row g-3 align-items-end">
      <div class="col-6">
        <label for="count" class="form-label">Click sayısı</label>
        <input class="form-control" id="count" type="number" min="1" max="50" value="10">
      </div>
      <div class="col-6">
        <label for="durationHours" class="form-label">Süre (saat)</label>
        <input class="form-control" id="durationHours" type="number" min="0" max="720" step="0.01" value="0">
      </div>
    </div>

    <div class="row g-3 align-items-end">
      <div class="col-6">
        <label for="maxAttempts" class="form-label">Retry</label>
        <input class="form-control" id="maxAttempts" type="number" min="1" max="10" value="3">
      </div>
      <div class="col-6">
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="headless" <%= headlessDefault ? "checked" : "" %>>
          <label class="form-check-label" for="headless">Headless</label>
        </div>
      </div>
    </div>

    <div>
      <label for="deviceMode" class="form-label">Ekran</label>
      <select class="form-select" id="deviceMode">
        <option value="desktop" selected>Desktop</option>
        <option value="mobile">Mobil</option>
      </select>
    </div>

    <div>
      <label for="proxyUrl" class="form-label">Proxy</label>
      <input class="form-control" id="proxyUrl" placeholder="http://user:pass@host:port">
    </div>

    <div class="cookie-input-group" data-cookie-input-group="create">
      <label class="form-label">Cookie</label>
      <div class="btn-group w-100 cookie-source-toggle" role="group" aria-label="Cookie kaynağı">
        <input type="radio" class="btn-check" name="cookieSource" id="cookieSourceText" value="text" autocomplete="off" checked>
        <label class="btn btn-outline-secondary" for="cookieSourceText">Metin gir</label>
        <input type="radio" class="btn-check" name="cookieSource" id="cookieSourceFile" value="file" autocomplete="off">
        <label class="btn btn-outline-secondary" for="cookieSourceFile">Dosya yükle</label>
        <input type="radio" class="btn-check" name="cookieSource" id="cookieSourcePool" value="pool" autocomplete="off">
        <label class="btn btn-outline-secondary" for="cookieSourcePool">Havuzdan kullan</label>
      </div>
      <textarea class="form-control mt-2" id="cookies" rows="5" data-cookie-text placeholder="name=value; name2=value2&#10;veya Netscape cookie file / JSON cookie array"></textarea>
      <input class="form-control mt-2 d-none" id="cookieFile" type="file" data-cookie-file accept=".txt,.json,.cookies,text/plain,application/json" multiple>
      <div class="form-text" data-cookie-file-name></div>
    </div>

    <button class="btn btn-primary btn-lg" type="submit" id="createTaskBtn">
      Task aç
    </button>
  </form>
</div>
