<div class="panel">
  <div class="panel-header">
    <h1>Yeni task</h1>
  </div>
  <form id="taskForm" class="vstack gap-3" autocomplete="off">
    <div>
      <label for="keywords" class="form-label">Keywordler</label>
      <textarea class="form-control" id="keywords" rows="6" placeholder="facebook&#10;instagram login"></textarea>
    </div>

    <div>
      <label for="targetAddress" class="form-label">Targeted site</label>
      <input class="form-control" id="targetAddress" placeholder="facebook.com">
    </div>

    <div class="row g-3 align-items-end">
      <div class="col-6">
        <label for="count" class="form-label">Click sayısı</label>
        <input class="form-control" id="count" type="number" min="1" max="50" value="10">
      </div>
      <div class="col-6">
        <label for="durationHours" class="form-label">Süre (saat)</label>
        <input class="form-control" id="durationHours" type="number" min="0" max="720" step="0.01" value="0">
      </div>
    </div>

    <div class="row g-3 align-items-end">
      <div class="col-6">
        <label for="maxAttempts" class="form-label">Retry</label>
        <input class="form-control" id="maxAttempts" type="number" min="1" max="10" value="3">
      </div>
      <div class="col-6">
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="headless" <%= headlessDefault ? "checked" : "" %>>
          <label class="form-check-label" for="headless">Headless</label>
        </div>
      </div>
    </div>

    <div>
      <label for="deviceMode" class="form-label">Ekran</label>
      <select class="form-select" id="deviceMode">
        <option value="desktop" selected>Desktop</option>
        <option value="mobile">Mobil</option>
      </select>
    </div>

    <div>
      <label for="proxyUrl" class="form-label">Proxy</label>
      <input class="form-control" id="proxyUrl" placeholder="http://user:pass@host:port">
    </div>

    <div>
      <label for="cookies" class="form-label">Cookie</label>
      <textarea class="form-control" id="cookies" rows="5" placeholder="name=value; name2=value2&#10;veya Netscape cookie file / JSON cookie array"></textarea>
    </div>

    <button class="btn btn-primary btn-lg" type="submit" id="createTaskBtn">
      Task aç
    </button>
  </form>
</div>
